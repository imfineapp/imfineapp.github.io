{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/compare/layout,_N_T_/[lang]/compare/[slug]/layout,_N_T_/[lang]/compare/[slug]/page,_N_T_/ru/compare/calm"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/compare/$d$slug/__PAGE__",
    "/$d$lang/compare/$d$slug",
    "/$d$lang/compare",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/stress-cards/layout,_N_T_/[lang]/stress-cards/page,_N_T_/en/stress-cards"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/stress-cards/__PAGE__",
    "/$d$lang/stress-cards",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
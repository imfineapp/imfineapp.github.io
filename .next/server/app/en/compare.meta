{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/compare/layout,_N_T_/[lang]/compare/page,_N_T_/en/compare"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/compare/__PAGE__",
    "/$d$lang/compare",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/pricing/layout,_N_T_/[lang]/pricing/page,_N_T_/en/pricing"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/pricing/__PAGE__",
    "/$d$lang/pricing",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}